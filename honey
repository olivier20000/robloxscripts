local blockedSounds = { Activated = true, Error = true, Success = true }
local function hardBlock(sound)
	if not sound:IsA("Sound") then return end
	if not blockedSounds[sound.Name] then return end
	sound.Volume = 0
	sound.Playing = false
	sound:GetPropertyChangedSignal("Playing"):Connect(function()
		if sound.Playing then
			sound.Playing = false
			sound:Stop()
		end
	end)
end
for _, obj in ipairs(game:GetDescendants()) do
	hardBlock(obj)
end
game.DescendantAdded:Connect(hardBlock)

