local tradeRunning = false
local fairTradeDetected = false
local addMoreDetected = false
local lastOfferDetected = false
local sendTradeAgain = true

local _ReplicatorClient = require(RS.Packages.ReplicatorClient)
local _tradeReplica = _ReplicatorClient.get(("Trade_%*"):format(LocalPlayer.UserId))

local _lastSign = nil
_tradeReplica:ListenRaw(function(state)
	if state == nil then
		_lastSign = nil
		fairTradeDetected = false
		addMoreDetected = false
		return
	end
	local users = _tradeReplica:TryIndex({ "active", "data", "users" })
	if typeof(users) ~= "table" then return end
	local otherSlot = nil
	for slot, uid in users do
		if uid ~= LocalPlayer.UserId then
			otherSlot = slot
			break
		end
	end
	if not otherSlot then return end
	_tradeReplica:Observe({ "active", "data", "players", otherSlot, "signText" }, function(signText)
		if typeof(signText) ~= "string" then signText = "" end
		if signText == "✅ Fair Trade" and signText ~= _lastSign then
			fairTradeDetected = true
		elseif signText == "➕ Add More" and signText ~= _lastSign then
			addMoreDetected = true
			fairTradeDetected = false
		elseif signText == "🧾 Last Offer" and signText ~= _lastSign then
			lastOfferDetected = true
			sendTradeAgain = false
		end
		_lastSign = signText
	end)
end)

local function autoadd()
	if tradeRunning then return end
	if not isTradeActive() then return end

	tradeRunning = true

	local plotFolder = cachedPlotFolder or getPlotFolder()
	if not plotFolder then
		tradeRunning = false
		return
	end

	local brainrotsToAdd = collectBrainrotsFromBase(plotFolder)
	if #brainrotsToAdd == 0 then
		tradeRunning = false
		return
	end

	local wantedSet = {}
	for _, name in ipairs(brainrotsToAdd) do
		wantedSet[name] = true
	end

	fairTradeDetected = false

	task.wait(_G.Settings.TradeStartDelay or 2)

	if not isTradeActive() then
		tradeRunning = false
		return
	end

	local sframe = getTradeScrollFrame()
	if not sframe then
		tradeRunning = false
		return
	end

	local children = sframe:GetChildren()
	local i = 1
	while i <= #children do
		if not isTradeActive() then
			tradeRunning = false
			return
		end
		if fairTradeDetected then
			task.spawn(fireReadyOrAccept)
			repeat task.wait(0.2) until addMoreDetected or not isTradeActive()
			if not isTradeActive() then
				tradeRunning = false
				return
			end
			addMoreDetected = false
			fairTradeDetected = false
		end
		local v = children[i]
		i = i + 1
		if v.Name:find("Selection") and v:FindFirstChild("Spacer") and v.Spacer:IsA("ImageButton") then
			local spacer = v.Spacer
			local titleLabel = spacer:FindFirstChild("Title")
			if titleLabel and titleLabel:IsA("TextLabel") then
				local title = cleanTradeTitle(titleLabel.Text)
				if wantedSet[title] then
					spacer.Visible = true
					task.wait(0.2)
					firesignal(spacer.Activated)
					task.wait(0.1)
					spacer.Visible = false
					task.wait(_G.Settings.AddDelay or 1.5)
				end
			end
		end
	end

	task.wait(_G.Settings.AcceptDelay or 2.5)
	fireReadyOrAccept()

	while isTradeActive() do
		task.wait(0.5)
	end

	tradeRunning = false
end

